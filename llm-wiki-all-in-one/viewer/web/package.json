{
  "name": "llm-wiki-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local wiki preview + audit feedback server for the llm-wiki skill.",
  "scripts": {
    "build": "node build-client.mjs",
    "test": "tsx --test server/routes/search.test.ts",
    "typecheck": "tsc --noEmit",
    "prestart": "npm run build",
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts"
  },
  "dependencies": {
    "@mdit/plugin-katex": "^0.25.2",
    "audit-shared": "file:../audit-shared",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.0.1",
    "markdown-it-attrs": "^4.2.0",
    "mermaid": "^11.14.0",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
